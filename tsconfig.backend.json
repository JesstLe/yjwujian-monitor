{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "allowImportingTsExtensions": false,
    "declaration": false,
    "isolatedModules": false,
    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "./src/shared/*"
      ]
    }
  },
  "include": [
    "src/backend/**/*",
    "src/shared/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-electron",
    "tests"
  ]
}
