{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "../dist-electron",
        "rootDir": "..",
        "types": [
            "node"
        ]
    },
    "include": [
        "./**/*.ts",
        "../src/backend/**/*.ts",
        "../src/shared/**/*.ts"
    ]
}